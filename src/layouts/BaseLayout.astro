---
import { ViewTransitions } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import Animations from '../components/Animations.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article = false } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
    <ViewTransitions />
  </head>
  <body>
    <ParticleBackground transition:persist="particle-bg" />
    <Header />
    <main id="main" class="page-content" style="position: relative; z-index: 1;">
      <slot />
    </main>
    <Footer />
    <Animations />
  </body>
</html>
