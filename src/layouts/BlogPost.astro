---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  heroImage?: string;
  readingTime?: string;
}

const { title, description, pubDate, heroImage, readingTime } = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage} article={true}>
  <article class="container blog-article">
    <header class="article-header">
      <a href="/blog" class="back-link">← Retour aux articles</a>
      <h1 class="gradient-text">{title}</h1>
      <div class="article-meta">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('fr-FR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
        {readingTime && <span class="reading-time">{readingTime}</span>}
      </div>
      {heroImage && (
        <div class="hero-image">
          <img src={heroImage} alt={title} loading="eager" />
        </div>
      )}
    </header>
    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    max-width: 800px;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    font-family: var(--font-code);
    font-size: 0.85rem;
    color: var(--muted-text);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .article-header h1 {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    color: var(--muted-text);
    font-size: 0.9rem;
    font-family: var(--font-code);
  }

  .reading-time::before {
    content: '·';
    margin-right: 0.5rem;
  }

  .hero-image {
    margin-top: 1.5rem;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--card-border);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .article-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted-text);
    font-style: italic;
  }

  .article-content :global(img) {
    max-width: 100%;
    border-radius: 0.75rem;
    border: 1px solid var(--card-border);
  }

  .article-content :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .article-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(139, 92, 246, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }

  .article-content :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  @media (max-width: 768px) {
    .article-header h1 {
      font-size: 1.6rem;
    }
  }
</style>
