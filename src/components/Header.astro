---
import { getSiteConfig } from '../utils/config';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.tsx';
import {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library, ExternalLink
} from 'lucide-astro';

const config = getSiteConfig();
const currentPath = Astro.url.pathname;

// Filter enabled navigation items based on features
const navItems = (config.header?.navigation || []).filter(
  (item: any) => item.enabled && config.features?.[item.label] !== false
);

// Filter enabled social links
const socialLinks = (config.header?.socialLinks || []).filter(
  (link: any) => link.enabled
);

// Map icon names to components
const iconMap: Record<string, any> = {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library
};
---

<header id="site-header">
  <div class="header-inner">
    <a class="skip-link" href="#main">Aller au contenu</a>

    <a href="/" class="header-brand">
      {config.header?.brandName || config.site.title}<span class="brand-cursor">_</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navItems.map((item: any) => {
        const href = item.external ? item.url : item.route;
        const isActive = !item.external && (
          currentPath === item.route ||
          (item.route !== '/' && currentPath.startsWith(item.route))
        );
        return (
          <a
            href={href}
            class:list={['nav-link', { active: isActive }]}
            aria-current={isActive ? 'page' : undefined}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            /{item.label}{item.external && <ExternalLink size={10} class="nav-link-external-icon" />}
          </a>
        );
      })}
    </nav>

    <div class="nav-right">
      <div class="social-links">
        {socialLinks.map((link: any) => {
          const Icon = iconMap[link.icon];
          return Icon ? (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              title={link.label}
            >
              <Icon size={18} />
            </a>
          ) : null;
        })}
      </div>
      <ThemeToggle />
      <MobileNav
          client:load
          navItems={navItems.map((item: any) => ({ label: item.label, route: item.external ? item.url : item.route, external: item.external }))}
          socialLinks={socialLinks.map((link: any) => ({ label: link.label, url: link.url, icon: link.icon }))}
          currentPath={currentPath}
        />
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--card-bg);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--card-border);
    transition: var(--transition-colors), box-shadow 0.3s ease;
  }

  header.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.12), 0 1px 0 var(--card-border);
  }

  .dark header.scrolled {
    box-shadow: 0 4px 30px rgba(0,0,0,0.4), 0 1px 0 var(--card-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 50px;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    z-index: 200;
    background: var(--accent);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
  }

  .skip-link:focus {
    left: 1rem;
    top: 0.5rem;
  }

  .header-brand {
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-code);
    letter-spacing: -0.5px;
    color: var(--text);
    display: inline-flex;
    align-items: baseline;
  }

  .header-brand:hover {
    color: var(--accent);
  }

  .brand-cursor {
    color: var(--accent);
    animation: blink-cursor 1s step-end infinite;
    font-weight: 400;
    margin-left: 1px;
  }

  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 2rem;
    flex: 1;
  }

  .nav-link {
    font-family: var(--font-code);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted-text);
    padding: 0.35rem 0.6rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-link.active {
    color: var(--accent);
    background: var(--glow);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    color: var(--muted-text);
    border-radius: 0.5rem;
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .social-links { display: none; }
  }

  .nav-link-external-icon {
    display: inline-block;
    vertical-align: middle;
    margin-left: 3px;
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* Hide mobile nav trigger on desktop — more reliable than Tailwind md:hidden
     inside a React island (Tailwind v4 scan may miss it). */
  :global(.mobile-nav-trigger) {
    display: none;
  }
  @media (max-width: 768px) {
    :global(.mobile-nav-trigger) {
      display: flex;
    }
  }
</style>

<script>
  (function () {
    const bootState = ((window as any).__siteHeaderBoot ??= {} as { scroll?: boolean });

    const refreshHeaderShadow = () => {
      const header = document.getElementById('site-header');
      if (window.scrollY > 8) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    };

    if (!bootState.scroll) {
      bootState.scroll = true;
      window.addEventListener('scroll', refreshHeaderShadow, { passive: true });
      document.addEventListener('astro:page-load', refreshHeaderShadow);
    }
    refreshHeaderShadow();
  })();
</script>
