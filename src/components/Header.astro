---
import { getSiteConfig } from '../utils/config';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.tsx';
import {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library
} from 'lucide-astro';

const config = getSiteConfig();
const currentPath = Astro.url.pathname;
const isDocSection = currentPath.startsWith('/docu');

// Filter enabled navigation items based on features
const navItems = (config.header?.navigation || []).filter(
  (item: any) => item.enabled && config.features?.[item.label] !== false
);

// Filter enabled social links
const socialLinks = (config.header?.socialLinks || []).filter(
  (link: any) => link.enabled
);

// Map icon names to components
const iconMap: Record<string, any> = {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library
};
---

<header id="site-header">
  <div class="header-inner">
    <a class="skip-link" href="#main">Aller au contenu</a>

    <a href="/" class="header-brand">
      {config.header?.brandName || config.site.title}<span class="brand-cursor">_</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navItems.map((item: any) => {
        const isActive = currentPath === item.route || 
          (item.route !== '/' && currentPath.startsWith(item.route));
        return (
          <a
            href={item.route}
            class:list={['nav-link', { active: isActive }]}
            aria-current={isActive ? 'page' : undefined}
          >
            /{item.label}
          </a>
        );
      })}
    </nav>

    <div class="nav-right">
      <div class="social-links">
        {socialLinks.map((link: any) => {
          const Icon = iconMap[link.icon];
          return Icon ? (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              title={link.label}
            >
              <Icon size={18} />
            </a>
          ) : null;
        })}
      </div>
      <ThemeToggle />
      {isDocSection ? (
        <button
          id="docs-mobile-menu-btn"
          class="mobile-nav-trigger docs-mobile-menu-trigger"
          aria-label="Navigation documentation"
          aria-expanded="false"
          aria-controls="starlight__sidebar"
          title="Navigation documentation"
        >
          <svg class="docs-mobile-menu-icon docs-mobile-menu-icon--open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="6" y2="6" />
            <line x1="4" x2="20" y1="12" y2="12" />
            <line x1="4" x2="20" y1="18" y2="18" />
          </svg>
          <svg class="docs-mobile-menu-icon docs-mobile-menu-icon--close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      ) : (
        <MobileNav
          client:load
          navItems={navItems.map((item: any) => ({ label: item.label, route: item.route }))}
          socialLinks={socialLinks.map((link: any) => ({ label: link.label, url: link.url, icon: link.icon }))}
          currentPath={currentPath}
        />
      )}
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--card-bg);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--card-border);
    transition: var(--transition-colors), box-shadow 0.3s ease;
  }

  header.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.12), 0 1px 0 var(--card-border);
  }

  .dark header.scrolled {
    box-shadow: 0 4px 30px rgba(0,0,0,0.4), 0 1px 0 var(--card-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 50px;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    z-index: 200;
    background: var(--accent);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
  }

  .skip-link:focus {
    left: 1rem;
    top: 0.5rem;
  }

  .header-brand {
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-code);
    letter-spacing: -0.5px;
    color: var(--text);
    display: inline-flex;
    align-items: baseline;
  }

  .header-brand:hover {
    color: var(--accent);
  }

  .brand-cursor {
    color: var(--accent);
    animation: blink-cursor 1s step-end infinite;
    font-weight: 400;
    margin-left: 1px;
  }

  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 2rem;
    flex: 1;
  }

  .nav-link {
    font-family: var(--font-code);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted-text);
    padding: 0.35rem 0.6rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-link.active {
    color: var(--accent);
    background: var(--glow);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    color: var(--muted-text);
    border-radius: 0.5rem;
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .social-links { display: none; }
  }

  .docs-mobile-menu-trigger {
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    background: none;
    border: none;
    border-radius: 0.5rem;
    color: var(--muted-text);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .docs-mobile-menu-trigger:hover {
    color: var(--accent);
  }

  .docs-mobile-menu-trigger[aria-expanded='true'] {
    color: var(--accent);
    background: var(--glow);
  }

  .docs-mobile-menu-icon--close { display: none; }
  .docs-mobile-menu-trigger[aria-expanded='true'] .docs-mobile-menu-icon--open { display: none; }
  .docs-mobile-menu-trigger[aria-expanded='true'] .docs-mobile-menu-icon--close { display: block; }

  /* Hide mobile nav trigger on desktop — more reliable than Tailwind md:hidden
     inside a React island (Tailwind v4 scan may miss it). */
  :global(.mobile-nav-trigger) {
    display: none;
  }
  @media (max-width: 768px) {
    :global(.mobile-nav-trigger) {
      display: flex;
    }
  }
</style>

<script>
  (function () {
    const bootState = ((window as any).__siteHeaderBoot ??= {} as { scroll?: boolean; docs?: boolean });

    const refreshHeaderShadow = () => {
      const header = document.getElementById('site-header');
      if (window.scrollY > 8) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    };

    if (!bootState.scroll) {
      bootState.scroll = true;
      window.addEventListener('scroll', refreshHeaderShadow, { passive: true });
      document.addEventListener('astro:page-load', refreshHeaderShadow);
    }
    refreshHeaderShadow();

    const setDocsExpanded = (expanded: boolean) => {
      const btn = document.getElementById('docs-mobile-menu-btn');
      if (btn) btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      document.body.toggleAttribute('data-mobile-menu-expanded', expanded);
    };

    const syncDocsButton = () => {
      const btn = document.getElementById('docs-mobile-menu-btn');
      if (!btn) return;
      btn.setAttribute('aria-expanded', document.body.hasAttribute('data-mobile-menu-expanded') ? 'true' : 'false');
    };

    const bindDocsButton = () => {
      const btn = document.getElementById('docs-mobile-menu-btn');
      if (!btn) return;
      if (btn.getAttribute('data-bound') === 'true') return;
      btn.setAttribute('data-bound', 'true');
      syncDocsButton();
      btn.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        setDocsExpanded(!isOpen);
      });
    };

    if (!bootState.docs) {
      bootState.docs = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setDocsExpanded(false);
      });
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        if (target.closest('#starlight__sidebar a')) {
          setDocsExpanded(false);
        }
      });
      document.addEventListener('astro:page-load', bindDocsButton);
    }

    bindDocsButton();
  })();
</script>
