---
---

<button id="theme-toggle" aria-label="Basculer le thème" class="theme-toggle" title="Basculer le thème">
  <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="icon" aria-hidden="true">
    <g fill="#FFD24C">
      <circle cx="12" cy="12" r="5" />
      <rect x="11.25" y="0.5" width="1.5" height="3" rx="0.75" />
      <rect x="11.25" y="20.5" width="1.5" height="3" rx="0.75" />
      <rect x="0.5" y="11.25" width="3" height="1.5" rx="0.75" />
      <rect x="20.5" y="11.25" width="3" height="1.5" rx="0.75" />
      <rect x="3.4" y="3.4" width="1.5" height="3" rx="0.75" transform="rotate(45 3.4 3.4)" />
      <rect x="3.4" y="17.6" width="1.5" height="3" rx="0.75" transform="rotate(-45 3.4 17.6)" />
      <rect x="19.1" y="3.4" width="1.5" height="3" rx="0.75" transform="rotate(-45 19.1 3.4)" />
      <rect x="19.1" y="17.6" width="1.5" height="3" rx="0.75" transform="rotate(45 19.1 17.6)" />
    </g>
  </svg>
  <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="icon hidden" aria-hidden="true">
    <path fill="#FFD24C" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0.5rem;
    background: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    color: var(--muted-text);
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .theme-toggle:hover {
    color: var(--accent);
  }

  .icon {
    display: block;
    width: 18px;
    height: 18px;
  }

  .hidden {
    display: none !important;
  }
</style>

<script is:inline>
  (function() {
    function setTheme(theme) {
      var sun = document.getElementById('sun-icon');
      var moon = document.getElementById('moon-icon');

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        document.documentElement.dataset.theme = 'dark';
        document.documentElement.style.backgroundColor = '#141416';
        sun && sun.classList.add('hidden');
        moon && moon.classList.remove('hidden');
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.dataset.theme = 'light';
        document.documentElement.style.backgroundColor = '#f8f8fa';
        sun && sun.classList.remove('hidden');
        moon && moon.classList.add('hidden');
      }
      localStorage.setItem('theme', theme);
      localStorage.setItem('starlight-theme', theme);
    }

    function initToggle() {
      // Sync icons with current state
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      setTheme(stored || (prefersDark ? 'dark' : 'light'));

      // Re-bind toggle (DOM may be new after View Transition)
      var toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.onclick = function() {
          var isDark = document.documentElement.classList.contains('dark');
          setTheme(isDark ? 'light' : 'dark');
        };
      }
    }

    initToggle();
    document.addEventListener('astro:page-load', initToggle);

    // System preference change listener (only once)
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
      if (!localStorage.getItem('theme')) {
        setTheme(e.matches ? 'dark' : 'light');
      }
    });
  })();
</script>
