---
/**
 * Custom Starlight Header — self-contained doc header.
 *
 * Intentionally does NOT re-use the React-based Header.astro because
 * the Vaul/React drawer fails to hydrate reliably inside the Starlight
 * page context (Starlight's own scripts conflict with client:load).
 *
 * Mobile nav is implemented with pure HTML + inline JS (no React, no Vaul)
 * so it works unconditionally in every browser context.
 */
import type { Props } from '@astrojs/starlight/props';
import { getSiteConfig } from '../../utils/config';
import ThemeToggle from '../ThemeToggle.astro';
import {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library
} from 'lucide-astro';

const config   = getSiteConfig();
const currentPath = Astro.url.pathname;

const navItems = (config.header?.navigation || []).filter(
  (item: any) => item.enabled && config.features?.[item.label] !== false
);

const socialLinks = (config.header?.socialLinks || []).filter(
  (link: any) => link.enabled
);

const iconMap: Record<string, any> = {
  Github, Gitlab, Linkedin, MessageCircle, Mail, Rss,
  User, Server, FileText, Library
};
---

<header id="site-header" class="sl-doc-header">
  <div class="sl-doc-header__inner">

    <!-- Brand -->
    <a href="/" class="sl-doc-header__brand">
      {config.header?.brandName || config.site.title}<span class="sl-doc-header__cursor">_</span>
    </a>

    <!-- Desktop nav -->
    <nav class="sl-doc-header__nav" aria-label="Navigation principale">
      {navItems.map((item: any) => {
        const isActive = currentPath === item.route ||
          (item.route !== '/' && currentPath.startsWith(item.route));
        return (
          <a
            href={item.route}
            class:list={['sl-doc-header__link', { 'sl-doc-header__link--active': isActive }]}
            aria-current={isActive ? 'page' : undefined}
          >
            /{item.label}
          </a>
        );
      })}
    </nav>

    <!-- Right group: theme + mobile trigger -->
    <div class="sl-doc-header__right">
      <ThemeToggle />

      <!-- Mobile hamburger — pure HTML, no React -->
      <button
        id="sl-mobile-nav-btn"
        class="sl-doc-header__mobile-btn"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="sl-mobile-nav-panel"
      >
        <!-- Hamburger -->
        <svg class="sl-mobile-icon sl-mobile-icon--open" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <!-- Close -->
        <svg class="sl-mobile-icon sl-mobile-icon--close" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile nav panel — rendered outside the fixed header so it can be full-screen -->
<div id="sl-mobile-nav-panel" class="sl-mobile-nav" aria-hidden="true">
  <nav aria-label="Navigation mobile" class="sl-mobile-nav__list">
    {navItems.map((item: any) => {
      const isActive = currentPath === item.route ||
        (item.route !== '/' && currentPath.startsWith(item.route));
      return (
        <a
          href={item.route}
          class:list={['sl-mobile-nav__link', { 'sl-mobile-nav__link--active': isActive }]}
        >
          <span class="sl-mobile-nav__slash">/</span>{item.label}
        </a>
      );
    })}
  </nav>

  {socialLinks.length > 0 && (
    <div class="sl-mobile-nav__socials">
      {socialLinks.map((link: any) => {
        const Icon = iconMap[link.icon];
        return Icon ? (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
            <Icon size={18} />
          </a>
        ) : null;
      })}
    </div>
  )}
</div>

<!-- Backdrop -->
<div id="sl-mobile-nav-backdrop" class="sl-mobile-nav__backdrop" aria-hidden="true"></div>

<script is:inline>
  (function () {
    var BOOT_KEY = '__docMobileNavBootstrapped';
    var BOUND_ATTR = 'data-doc-mobile-nav-bound';

    function closeCurrentMenu() {
      var btn = document.getElementById('sl-mobile-nav-btn');
      var panel = document.getElementById('sl-mobile-nav-panel');
      var backdrop = document.getElementById('sl-mobile-nav-backdrop');
      if (!btn || !panel || !backdrop) return;
      btn.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
      panel.classList.remove('is-open');
      backdrop.classList.remove('is-visible');
      document.body.style.overflow = '';
    }

    function bindDocMobileNav() {
      var btn = document.getElementById('sl-mobile-nav-btn');
      var panel = document.getElementById('sl-mobile-nav-panel');
      var backdrop = document.getElementById('sl-mobile-nav-backdrop');
      if (!btn || !panel || !backdrop) return;
      if (btn.getAttribute(BOUND_ATTR) === 'true') return;
      btn.setAttribute(BOUND_ATTR, 'true');

      function open() {
        btn.setAttribute('aria-expanded', 'true');
        panel.setAttribute('aria-hidden', 'false');
        panel.classList.add('is-open');
        backdrop.classList.add('is-visible');
        document.body.style.overflow = 'hidden';
      }

      btn.addEventListener('click', function () {
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        isOpen ? closeCurrentMenu() : open();
      });

      backdrop.addEventListener('click', closeCurrentMenu);

      panel.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', closeCurrentMenu);
      });
    }

    if (!window[BOOT_KEY]) {
      window[BOOT_KEY] = true;
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeCurrentMenu();
      });
      document.addEventListener('astro:page-load', bindDocMobileNav);
    }

    bindDocMobileNav();
  })();
</script>

<style>
  /* ── Doc-specific header — same visual language as the site header ── */
  .sl-doc-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 50px;
    z-index: 100;
    background: var(--card-bg, rgba(20,20,22,0.85));
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--card-border, rgba(255,255,255,0.06));
  }

  .sl-doc-header__inner {
    display: flex;
    align-items: center;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    gap: 0.5rem;
  }

  .sl-doc-header__brand {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text, #e4e4e7);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sl-doc-header__brand:hover {
    color: var(--accent, #d4845a);
  }

  .sl-doc-header__cursor {
    color: var(--accent, #d4845a);
    animation: blink-cursor 1s step-end infinite;
    font-weight: 400;
    margin-left: 1px;
  }

  .sl-doc-header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 1.5rem;
    flex: 1;
  }

  .sl-doc-header__link {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted-text, #737378);
    padding: 0.3rem 0.55rem;
    border-radius: 0.5rem;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .sl-doc-header__link:hover {
    color: var(--accent, #d4845a);
  }

  .sl-doc-header__link--active {
    color: var(--accent, #d4845a);
    background: var(--glow, rgba(212,132,90,0.10));
  }

  .sl-doc-header__right {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  /* Mobile button — hidden on desktop */
  .sl-doc-header__mobile-btn {
    display: none;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    background: none;
    border: none;
    border-radius: 0.5rem;
    color: var(--muted-text, #737378);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s ease;
  }

  .sl-doc-header__mobile-btn:hover {
    color: var(--accent, #d4845a);
  }

  @media (max-width: 768px) {
    .sl-doc-header__nav { display: none; }
    .sl-doc-header__mobile-btn { display: flex; }
  }

  /* Open/close icon swap */
  .sl-mobile-icon--close { display: none; }
  .sl-doc-header__mobile-btn[aria-expanded='true'] .sl-mobile-icon--open  { display: none; }
  .sl-doc-header__mobile-btn[aria-expanded='true'] .sl-mobile-icon--close { display: block; }

  /* ── Mobile nav panel ── */
  .sl-mobile-nav {
    position: fixed;
    top: 50px;
    left: 0;
    right: 0;
    z-index: 200;
    background: color-mix(in srgb, var(--surface, #1c1c1f) 92%, transparent);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border-bottom: 1px solid var(--card-border, rgba(255,255,255,0.06));
    padding: 1rem 1.5rem 1.5rem;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .sl-mobile-nav.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .sl-mobile-nav__list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .sl-mobile-nav__link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary, #a8a8b0);
    padding: 0.65rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .sl-mobile-nav__link:hover,
  .sl-mobile-nav__link--active {
    color: var(--accent, #d4845a);
    background: var(--glow, rgba(212,132,90,0.10));
  }

  .sl-mobile-nav__slash {
    color: var(--link-color, #5ecfba);
    font-size: 0.9em;
    opacity: 0.7;
  }

  .sl-mobile-nav__socials {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--card-border, rgba(255,255,255,0.06));
  }

  .sl-mobile-nav__socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    color: var(--muted-text, #737378);
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .sl-mobile-nav__socials a:hover {
    color: var(--accent, #d4845a);
  }

  /* ── Backdrop ── */
  .sl-mobile-nav__backdrop {
    position: fixed;
    inset: 0;
    z-index: 190;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .sl-mobile-nav__backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Cursor blink ── */
  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Light theme ── */
  [data-theme='light'] .sl-mobile-nav__slash {
    color: var(--link-color, #1a8a7a);
  }
</style>
