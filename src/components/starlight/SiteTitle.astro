---
/**
 * Custom SiteTitle for Starlight — adds a "← retour au site" link
 */
---
<div class="site-title-wrapper">
  <a href="/" class="back-to-site" title="Retour au site principal">
    ← adenyrr.me
  </a>
  <span class="title-separator">/</span>
  <a href="/docu/" class="doc-title">documentation</a>
</div>

<style>
  .site-title-wrapper {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.9rem;
  }
  .back-to-site {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-to-site:hover {
    color: var(--sl-color-accent);
  }
  .title-separator {
    color: var(--sl-color-gray-4);
  }
  .doc-title {
    color: var(--sl-color-white);
    font-weight: 600;
    text-decoration: none;
  }
</style>
