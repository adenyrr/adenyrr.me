---
/**
 * Custom Starlight Pagination — adds a PDF/print export button
 * above the standard prev/next pagination links.
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Pagination.astro';
---

<div class="doc-export-bar">
  <button class="doc-export-btn" id="export-pdf-btn" title="Exporter en PDF">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
      <polyline points="10 9 9 9 8 9"/>
    </svg>
    Exporter en PDF
  </button>
</div>

<Default {...Astro.props}><slot /></Default>

<script>
  function bindExport() {
    const btn = document.getElementById('export-pdf-btn');
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = 'true';
    btn.addEventListener('click', () => window.print());
  }
  bindExport();
  document.addEventListener('astro:page-load', bindExport);
</script>

<style is:global>
  .doc-export-bar {
    display: flex;
    justify-content: flex-end;
    padding: 0.75rem 0 1rem;
    margin-top: 1rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }

  .doc-export-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.78rem;
    font-family: var(--sl-font-mono, monospace);
    color: var(--sl-color-gray-2, #737378);
    background: transparent;
    border: 1px solid var(--sl-color-gray-4, #3a3a40);
    border-radius: 0.4rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .doc-export-btn:hover {
    color: var(--sl-color-accent, #d4845a);
    border-color: var(--sl-color-accent, #d4845a);
    background: rgba(212, 132, 90, 0.06);
  }

  .doc-export-btn svg {
    flex-shrink: 0;
  }

  @media print {
    .doc-export-bar { display: none !important; }
  }
</style>
