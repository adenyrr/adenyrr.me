<script>
  /* Use event delegation — one stable listener on document, never needs
     re-binding after View Transition DOM swaps.  */
  function handleTabClick(e: MouseEvent) {
    const tab = (e.target as Element).closest<HTMLElement>('[data-tab]');
    // Only act when a .tab button was clicked (guard against other [data-tab] elements)
    if (!tab || !tab.classList.contains('tab')) return;

    const target = tab.dataset.tab;

    // Deactivate all tabs & hide all panels (query live DOM at click time)
    document.querySelectorAll<HTMLElement>('.tab').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll<HTMLElement>('.tab-panel').forEach(p => p.classList.add('hidden'));

    // Activate clicked tab
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');

    // Show target panel and re-trigger slide-in animations
    const panel = document.querySelector<HTMLElement>(`[data-panel="${target}"]`);
    if (panel) {
      panel.classList.remove('hidden');
      panel.querySelectorAll('.slide-in').forEach(el => {
        el.classList.remove('slide-in');
        void (el as HTMLElement).offsetWidth;
        el.classList.add('slide-in');
      });
    }
  }

  // Single registration — module runs once, delegation handles all navigations
  document.addEventListener('click', handleTabClick);

  // Scroll reveal + counter animation handled globally by Animations.astro (GSAP)
</script>
